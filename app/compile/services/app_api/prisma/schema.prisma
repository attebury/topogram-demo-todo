generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  draft
  active
  completed
  archived
}

enum TaskPriority {
  low
  medium
  high
}

enum ProjectStatus {
  active
  archived
}

model Task {
  id String @db.Uuid @id
  title String
  description String?
  status TaskStatus @default(draft)
  priority TaskPriority @default(medium)
  owner_id String? @db.Uuid
  owner User? @relation("Task_owner_id_to_User", fields: [owner_id], references: [id])
  project_id String @db.Uuid
  project Project @relation("Task_project_id_to_Project", fields: [project_id], references: [id])
  created_at DateTime @db.Timestamptz(3)
  updated_at DateTime @db.Timestamptz(3)
  completed_at DateTime? @db.Timestamptz(3)
  due_at DateTime? @db.Timestamptz(3)
  @@index([project_id, status])
  @@index([owner_id, status])
  @@map("tasks")
}

model Project {
  id String @db.Uuid @id
  name String @unique
  description String?
  status ProjectStatus @default(active)
  owner_id String? @db.Uuid
  owner User? @relation("Project_owner_id_to_User", fields: [owner_id], references: [id])
  created_at DateTime @db.Timestamptz(3)
  tasks Task[] @relation("Task_project_id_to_Project")
  @@index([owner_id, status])
  @@map("projects")
}

model User {
  id String @db.Uuid @id
  email String @unique
  display_name String
  is_active Boolean @default(true)
  created_at DateTime @db.Timestamptz(3)
  tasks Task[] @relation("Task_owner_id_to_User")
  projects Project[] @relation("Project_owner_id_to_User")
  @@map("users")
}
