{
  "type": "compile_check_plan",
  "name": "Todo Generated Compile Checks",
  "projections": {
    "api": "proj_api",
    "ui": "proj_ui_web",
    "db": "proj_db_postgres"
  },
  "topology": {
    "components": [
      {
        "id": "app_api",
        "type": "api",
        "projection": "proj_api",
        "generator": {
          "id": "topogram/hono",
          "version": "1"
        }
      },
      {
        "id": "app_sveltekit",
        "type": "web",
        "projection": "proj_ui_web",
        "generator": {
          "id": "topogram/sveltekit",
          "version": "1"
        }
      },
      {
        "id": "app_postgres",
        "type": "database",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "topogram/postgres",
          "version": "1"
        }
      }
    ]
  },
  "checks": [
    {
      "id": "server_typecheck",
      "cwd": "services/app_api",
      "install": "npm install --no-audit --no-fund",
      "command": "npm run check"
    },
    {
      "id": "web_typecheck",
      "cwd": "web/app_sveltekit",
      "install": "npm install --no-audit --no-fund",
      "command": "npm run check"
    },
    {
      "id": "web_build",
      "cwd": "web/app_sveltekit",
      "install": "npm install --no-audit --no-fund",
      "command": "npm run build"
    }
  ]
}
