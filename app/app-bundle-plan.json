{
  "type": "app_bundle_plan",
  "name": "Topogram Todo App Bundle",
  "projections": {
    "api": "proj_api",
    "ui": "proj_ui_web",
    "db": "proj_db_postgres",
    "dbPlatform": "db_postgres"
  },
  "topology": {
    "components": [
      {
        "id": "app_api",
        "type": "api",
        "projection": "proj_api",
        "generator": {
          "id": "topogram/hono",
          "version": "1"
        },
        "port": 3000,
        "api": null,
        "database": "app_postgres"
      },
      {
        "id": "app_sveltekit",
        "type": "web",
        "projection": "proj_ui_web",
        "generator": {
          "id": "topogram/sveltekit",
          "version": "1"
        },
        "port": 5173,
        "api": "app_api",
        "database": null
      },
      {
        "id": "app_postgres",
        "type": "database",
        "projection": "proj_db_postgres",
        "generator": {
          "id": "topogram/postgres",
          "version": "1"
        },
        "port": 5432,
        "api": null,
        "database": null
      }
    ]
  },
  "runtimeReference": {
    "localDbProjectionId": "proj_db_postgres",
    "serviceName": "topogram-todo-server",
    "ports": {
      "server": 3000,
      "web": 5173
    },
    "environment": {
      "name": "Todo Local Runtime Stack",
      "databaseName": "topogram_todo",
      "envExample": "TOPOGRAM_AUTH_PROFILE=bearer_demo\nTOPOGRAM_AUTH_TOKEN=topogram-todo-demo-token\nTOPOGRAM_AUTH_USER_ID=11111111-1111-4111-8111-111111111111\nTOPOGRAM_AUTH_PERMISSIONS=*\nPUBLIC_TOPOGRAM_AUTH_TOKEN=topogram-todo-demo-token\nPUBLIC_TOPOGRAM_AUTH_USER_ID=11111111-1111-4111-8111-111111111111\nPUBLIC_TOPOGRAM_AUTH_PERMISSIONS=*\nPUBLIC_TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333\nPUBLIC_TOPOGRAM_DEMO_CONTAINER_ID=22222222-2222-4222-8222-222222222222\nTOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333\nTOPOGRAM_DEMO_CONTAINER_ID=22222222-2222-4222-8222-222222222222"
    },
    "compileCheck": {
      "name": "Todo Generated Compile Checks"
    },
    "smoke": {
      "name": "Todo Runtime Smoke Plan",
      "bundleTitle": "Todo Runtime Smoke Bundle",
      "defaultContainerEnvVar": "TOPOGRAM_DEMO_CONTAINER_ID",
      "webPath": "/tasks",
      "expectText": "Tasks",
      "createPath": "/tasks",
      "getPathPrefix": "/tasks/",
      "listPath": "/tasks",
      "createPayload": {
        "title": "Smoke Test Task",
        "containerField": "project_id",
        "extraFields": {
          "owner_id": "__DEMO_USER_ID__"
        }
      },
      "verification": {
        "methods": [
          "smoke"
        ],
        "sources": [
          {
            "id": "ver_runtime_smoke",
            "name": "Todo runtime smoke",
            "method": "smoke",
            "validates": [
              "cap_create_task",
              "cap_get_task",
              "cap_list_tasks"
            ]
          }
        ],
        "scenarios": [
          {
            "id": "tasks_page_responds",
            "label": "tasks page responds"
          },
          {
            "id": "create_task_smoke",
            "label": "create task smoke"
          },
          {
            "id": "get_created_task_smoke",
            "label": "get created task smoke"
          },
          {
            "id": "list_tasks_smoke",
            "label": "list tasks smoke"
          }
        ]
      }
    },
    "runtimeCheck": {
      "name": "Todo Runtime Check Plan",
      "bundleTitle": "Todo Runtime Check Bundle",
      "requiredEnv": [
        "TOPOGRAM_API_BASE_URL",
        "TOPOGRAM_WEB_BASE_URL",
        "TOPOGRAM_DEMO_CONTAINER_ID",
        "TOPOGRAM_DEMO_PRIMARY_ID"
      ],
      "demoContainerEnvVar": "TOPOGRAM_DEMO_CONTAINER_ID",
      "demoPrimaryEnvVar": "TOPOGRAM_DEMO_PRIMARY_ID",
      "lookupPaths": {
        "project": "/lookups/projects",
        "user": "/lookups/users"
      },
      "stageNotes": [
        {
          "id": "environment",
          "summary": "required env, web readiness, API health, API readiness, and DB-backed seeded task lookup"
        },
        {
          "id": "api",
          "summary": "core task happy paths, export/job flows, generated lookup endpoints, and important negative cases"
        }
      ],
      "notes": [
        "Mutating checks create, update, complete, and archive a runtime-check task.",
        "Export checks submit a task export job, verify job status, and verify the download endpoint.",
        "Runtime checks also verify the generated project and user lookup endpoints.",
        "Later stages are skipped if environment readiness fails.",
        "The generated server exposes both `/health` and `/ready`.",
        "Use the smoke bundle for a faster minimal confidence check.",
        "Use this runtime-check bundle for richer staged verification and JSON reporting."
      ],
      "verification": {
        "methods": [
          "runtime"
        ],
        "sources": [
          {
            "id": "ver_create_task_policy",
            "name": "Create task policy",
            "method": "runtime",
            "validates": [
              "cap_create_task",
              "rule_no_task_creation_in_archived_project",
              "rule_only_active_users_may_own_tasks"
            ]
          },
          {
            "id": "ver_task_runtime_flow",
            "name": "Task runtime flow",
            "method": "runtime",
            "validates": [
              "cap_create_task",
              "cap_get_task",
              "cap_list_tasks",
              "cap_update_task",
              "cap_complete_task",
              "cap_delete_task",
              "cap_export_tasks",
              "cap_get_task_export_job",
              "cap_download_task_export"
            ]
          }
        ],
        "scenarios": [
          {
            "id": "create_task_in_active_project",
            "label": "create task in active project"
          },
          {
            "id": "reject_task_in_archived_project",
            "label": "reject task in archived project"
          },
          {
            "id": "reject_assignment_to_inactive_user",
            "label": "reject assignment to inactive user"
          },
          {
            "id": "create_task_runtime",
            "label": "create task runtime"
          },
          {
            "id": "get_created_task_runtime",
            "label": "get created task runtime"
          },
          {
            "id": "list_tasks_runtime",
            "label": "list tasks runtime"
          },
          {
            "id": "update_task_runtime",
            "label": "update task runtime"
          },
          {
            "id": "complete_task_runtime",
            "label": "complete task runtime"
          },
          {
            "id": "delete_task_runtime",
            "label": "delete task runtime"
          },
          {
            "id": "export_tasks_runtime",
            "label": "export tasks runtime"
          },
          {
            "id": "get_task_export_job_runtime",
            "label": "get task export job runtime"
          },
          {
            "id": "download_task_export_runtime",
            "label": "download task export runtime"
          }
        ]
      }
    },
    "appBundle": {
      "name": "Topogram Todo App Bundle",
      "demoContainerName": "Demo Project",
      "demoPrimaryTitle": "Seeded Demo Task"
    },
    "demoEnv": {
      "userId": "11111111-1111-4111-8111-111111111111",
      "containerId": "22222222-2222-4222-8222-222222222222",
      "primaryId": "33333333-3333-4333-8333-333333333333"
    }
  },
  "profiles": {
    "environment": "local_process",
    "deployment": "fly_io"
  },
  "commands": {
    "bootstrap": "./scripts/bootstrap.sh",
    "dev": "./scripts/dev.sh",
    "compile": "./scripts/compile-check.sh",
    "runtime": "./scripts/runtime.sh",
    "smoke": "./scripts/smoke.sh",
    "runtimeCheck": "./scripts/runtime-check.sh",
    "deployCheck": "./scripts/deploy-check.sh"
  },
  "layout": {
    "apps": "apps",
    "deploy": "deploy",
    "smoke": "smoke",
    "runtimeCheck": "runtime-check",
    "compile": "compile",
    "services": "apps/services",
    "web": "apps/web",
    "db": "apps/db",
    "native": "apps/native"
  }
}
